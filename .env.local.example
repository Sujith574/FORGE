# ============================================================
# FORGE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# Groq API Key
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# MongoDB Connection String
# Get from: MongoDB Atlas → Cluster → Connect → Drivers
MONGODB_URI=mongodb+srv://user:pass@cluster.mongodb.net/forge?retryWrites=true&w=majority

# JWT Secret
# Generate a random string (e.g. openssl rand -base64 32)
JWT_SECRET=your_random_jwt_secret_here

# App environment
NODE_ENV=development
