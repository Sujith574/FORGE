# ============================================================
# FORGE — Environment Variables
# Copy this file to .env.local and fill in your values.
# NEVER commit .env.local to Git.
# ============================================================

# Groq API Key
# Get from: https://console.groq.com → API Keys
GROQ_API_KEY=gsk_your_groq_api_key_here

# Supabase Project URL
# Get from: Supabase Dashboard → Settings → API
NEXT_PUBLIC_SUPABASE_URL=https://your-project-id.supabase.co

# Supabase Anon Key (safe for browser — respects RLS)
# Get from: Supabase Dashboard → Settings → API → anon public
NEXT_PUBLIC_SUPABASE_ANON_KEY=eyJ...

# Supabase Service Role Key (SERVER ONLY — bypasses RLS)
# Get from: Supabase Dashboard → Settings → API → service_role secret
# NEVER expose this to the browser
SUPABASE_SERVICE_KEY=eyJ...

# App environment
NODE_ENV=development
